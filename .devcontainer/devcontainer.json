{
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "BASE_IMAGE_VARIANT": "debian",
      "BASE_IMAGE_VERSION": "11",
      "CUDA_VERSION": "11.3.1",
      "CUDNN_VERSION": "8.2.4",
      "OCAML_VERSION": "4",
      "OPAM_VERSION": "2",
      "TORCH_VERSION": "1.10.2"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools-extension-pack"
      ]
    }
  },
  "features": {
    "ghcr.io/julialang/devcontainer-features/julia:1": {}
  },
  "hostRequirements": {
    "gpu": "optional"
  },
  "postCreateCommand": "opam init --disable-sandboxing --auto-setup; sudo chown -R vscode:vscode /opt/juliaup /opt/julia_depot"
}
