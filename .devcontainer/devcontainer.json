{
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "BASE_IMAGE_TAG": "debian-11",
      "OCAML_VERSION": "4",
      "OPAM_VERSION": "2",
      "TORCH_VERSION": "1.10.2"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools-extension-pack"
      ]
    }
  },
  "features": {
    "ghcr.io/julialang/devcontainer-features/julia:1": {}
  },
  "postCreateCommand": "opam init --auto-setup"
}
